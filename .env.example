# Watchdog Configuration
DB_PATH=watchdog.db
DATA_DIR=data

# Anomaly detection defaults
DEFAULT_Z_THRESHOLD=2.0
DEFAULT_WINDOW_MINUTES=15

# Webhook settings (leave blank to disable outbound POST)
WEBHOOK_URL=https://hooks.example.com/sre/alerts

# SMTP settings (leave blank to disable email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

LOG_LEVEL=INFO
